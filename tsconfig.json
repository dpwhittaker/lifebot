{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest"],
    "baseUrl": ".",
    "paths": {
      "whisper.rn": ["node_modules/whisper.rn/lib/typescript/index.d.ts"],
      "whisper.rn/src/realtime-transcription": [
        "node_modules/whisper.rn/lib/typescript/realtime-transcription/index.d.ts"
      ],
      "whisper.rn/src/realtime-transcription/adapters/*": [
        "node_modules/whisper.rn/lib/typescript/realtime-transcription/adapters/*"
      ]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "env.d.ts"],
  "exclude": ["**/node_modules", "**/Pods", "android", "ios"]
}
