# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — your key never leaves your machine.

# Get one at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Optional. Defaults to gemini-3.1-flash-lite-preview (highest free-tier quota).
# Any Gemini model that accepts audio input via inlineData works.
# VITE_GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Optional. By default the app POSTs runtime logs to `/lifebot/logs` (relative
# to the page). Override only if you serve the app under a different path or
# want to disable uploads (set to an empty string).
# VITE_LIFEBOT_LOG_URL=
